[Unit]
Description=Manshot API (FastAPI/Uvicorn)
After=network.target

[Service]
Type=simple
User=mandre
Group=mandre
WorkingDirectory=/home/mandre/manshot
EnvironmentFile=/home/mandre/manshot/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/mandre/manshot/.venv/bin/uvicorn api.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
KillSignal=SIGINT
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
